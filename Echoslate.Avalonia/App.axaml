<Application x:Class="Echoslate.Avalonia.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Echoslate.Avalonia.Converters"
             xmlns:services="clr-namespace:Echoslate.Core.Services;assembly=Echoslate.Core"
             RequestedThemeVariant="Dark"
             >

    <Application.Resources>
        <services:BrushService x:Key="BrushService"
                               x:Shared="True"
                               />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <FontFamily x:Key="AppFont">
            avares://Echoslate.Core/Assets/Fonts/#Inter,
            avares://Echoslate.Core/Assets/Fonts/#Noto Sans SC,
            Segoe UI,
            Microsoft YaHei,
            SimSun,
            sans-serif
        </FontFamily>
        <FontFamily x:Key="MonoFont">
            avares://Echoslate.Core/Assets/Fonts/#JetBrains Mono,
            Consolas,
            Courier New,
            monospace
        </FontFamily>

        <StaticResource x:Key="MenuFlyoutItemBackgroundPointerOver"
                        ResourceKey="AccentBrush"
                        />
        <StaticResource x:Key="MenuFlyoutItemBackgroundPressed"
                        ResourceKey="LightAccentBrush"
                        />
        <StaticResource x:Key="MenuFlyoutSubItemBackgroundSubMenuOpened"
                        ResourceKey="LightAccentBrush"
                        />
        <StreamGeometry x:Key="ExclamationTriangleGeometry">M12 2L1 21h22L12 2zm0 3.5L20.5 19H3.5L12 5.5zm0 5v5h-1v-5h1zm0 7h-1v-1h1v1z</StreamGeometry>
        <StreamGeometry x:Key="PriorityFlagGeometry">M 0 0 v -17 h 2 l 14 5 l -14 6 v 6 h -2 z</StreamGeometry>
        <StreamGeometry x:Key="BellGeometry">M 0 0 l 2 -3 v -4 l 2 -4 l 2 -1 l -1 -1 l 1 -1 h 1 l 1 1 l -1 1 l 2 1 l 2 4 v 4 l 2 3 h -6 l 1 1 l -1 1 l -1 0 l -1 -1 l 1 -1 z</StreamGeometry>
        <StreamGeometry x:Key="SnoozeGeometry">M 1 -5 H 4 V -4 L 2 -1 H 4 V 0 H 1 V -1 L 3 -4 H 1 Z M 7 -2 L 4 -2 L 4 -3 L 6 -5 L 4 -5 L 4 -6 L 7 -6 L 7 -5 L 5 -3 L 7 -3 Z M 7 -4 L 7 -5 L 8 -6 L 7 -6 L 7 -7 L 9 -7 L 9 -6 L 8 -5 L 9 -5 L 9 -4 Z</StreamGeometry>
    </Application.Resources>
    <Application.Styles>
        <SimpleTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Simple.xaml" />


        <!--  Global  -->
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        </Style>
        <Style Selector="UserControl">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="Grid">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
        </Style>


        <!--  TextBox / TextBlock / Label style  -->
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
        </Style>
        <Style Selector="Label">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
        </Style>

        <Style Selector="Label.header-label">
            <Setter Property="Background" Value="{DynamicResource ControlBrushBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="20" />
            <!-- <Setter Property="BorderThickness" Value="1" /> -->
            <!-- <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /> -->
            <!-- <Setter Property="CornerRadius" Value="7" /> -->
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Label.reminder-label">
            <Setter Property="Content">
                <Setter.Value>
                    <Template>
                        <PathIcon Width="24"
                                  Height="24"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  Data="{StaticResource BellGeometry}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  />
                    </Template>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Label.snooze-label">
            <Setter Property="Content">
                <Setter.Value>
                    <Template>
                        <PathIcon Width="24"
                                  Height="24"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  Data="{StaticResource SnoozeGeometry}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  />
                    </Template>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Base Button  -->
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DarkAccentBrush}" />
            </Style>
            <Style Selector="^.IsEnabled">
                <Setter Property="Background" Value="{DynamicResource ButtonDisabledBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            </Style>
        </Style>


        <!--  OK Button  -->
        <Style Selector="Button.ok">
            <Setter Property="Content" Value="Ok" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Width" Value="140" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource LightAccentBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>
        </Style>

        <!--  Cancel Button  -->
        <Style Selector="Button.cancel">
            <Setter Property="Content" Value="Cancel" />
            <Setter Property="Background" Value="{DynamicResource DarkDangerRedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DarkDangerRedBrush}" />
            <Setter Property="Width" Value="140" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource LightDangerRedBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource DarkerDangerRedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DangerRedBrush}" />
            </Style>
        </Style>

        <!--  Complete Button  -->
        <Style Selector="Button.complete">
            <Setter Property="Content" Value="Complete" />
            <Setter Property="Background" Value="{DynamicResource SuccessGreenBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessGreenBrush}" />
            <Setter Property="Width" Value="140" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource LightSuccessGreenBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource DarkSuccessGreenBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SuccessGreenBrush}" />
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Background" Value="{DynamicResource DisabledSuccessGreenBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DisabledSuccessGreenBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            </Style>
        </Style>

        <!--  Snooze Button  -->
        <Style Selector="Button.snooze">
            <Setter Property="Width" Value="140" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Vertical Button  -->
        <Style Selector="Button.vertical">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            >
                        <LayoutTransformControl HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                >
                            <LayoutTransformControl.LayoutTransform>
                                <RotateTransform Angle="-90" />
                            </LayoutTransformControl.LayoutTransform>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              />
                        </LayoutTransformControl>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DarkAccentBrush}" />
            </Style>
            <Style Selector="^.IsEnabled">
                <Setter Property="Background" Value="{DynamicResource ButtonDisabledBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            </Style>
        </Style>

        <!--  Vertical Commit Button  -->
        <Style Selector="Button.vertical-commit-button">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            >
                        <LayoutTransformControl HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                >
                            <LayoutTransformControl.LayoutTransform>
                                <RotateTransform Angle="-90" />
                            </LayoutTransformControl.LayoutTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              />
                        </LayoutTransformControl>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource LightAccentBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Opacity" Value="0.5" />
            </Style>
        </Style>


        <!--  Version Buttons  -->
        <Style Selector="Button.version-number-button">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                >
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#20000000" />
            </Style>
        </Style>

        <!--  Base FilterButton style  -->
        <Style Selector="Button.filter-button">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            >
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>

            <Style Selector="^.selected">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            </Style>
        </Style>

        <!--  SeverityButton  -->
        <Style Selector="Button.severity-button">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            >
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>
            <Style Selector="^.selected /template/ Border#PART_Border">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>
        </Style>

        <!--  Header Buttons  -->
        <Style Selector="Button.header-button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                >
                            <ContentPresenter Margin="21,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}" />
            </Style>
        </Style>

        <Style Selector="Button.severity-header-button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Content">
                <Setter.Value>
                    <Template>
                        <PathIcon Width="24"
                                  Height="24"
                                  Data="{StaticResource ExclamationTriangleGeometry}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  />
                    </Template>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Button.reminder-header-button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Content">
                <Setter.Value>
                    <Template>
                        <PathIcon Width="24"
                                  Height="24"
                                  Data="{StaticResource BellGeometry}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  />
                    </Template>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.snooze-header-button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Content">
                <Setter.Value>
                    <Template>
                        <PathIcon Width="24"
                                  Height="24"
                                  Data="{StaticResource SnoozeGeometry}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  />
                    </Template>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Button.priority-header-button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Content">
                <Setter.Value>
                    <Template>
                        <PathIcon Width="24"
                                  Height="24"
                                  Data="{StaticResource PriorityFlagGeometry}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  />
                    </Template>
                </Setter.Value>
            </Setter>
        </Style>


        <!--  DataGrid  -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
            <!-- <Setter Property="BorderThickness" Value="0,0,1,1" /> -->
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
        </Style>
        <!-- <Style Selector="DataGridRow:pointerover"> -->
        <!-- <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" /> -->
        <!-- <Setter Property="Background" Value="{DynamicResource DangerRedBrush}" /> -->
        <!-- <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" /> -->
        <!-- </Style> -->
        <!-- <Style Selector="DataGridRow:selected"> -->
        <!-- <Setter Property="Background" Value="{DynamicResource AccentBrush}" /> -->
        <!-- <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" /> -->
        <!-- </Style> -->
        <Style Selector="DataGridRow:selected:focus">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        </Style>
        <Style Selector="DataGridRow:selected /template/ Border">
            <Setter Property="Opacity" Value="0.50" />
            <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
        </Style>
        <Style Selector="DataGridRow:pointerover /template/ Border">
            <Setter Property="Opacity" Value="0.50" />
            <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
        </Style>

        <Style Selector="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <!-- <Style Selector="DataGridCell:pointerover"> -->
        <!-- <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" /> -->
        <!-- <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" /> -->
        <!-- </Style> -->

        <Style Selector="DataGridColumnHeader &gt; ContentPresenter">
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="DataGridColumnHeader /template/ ContentPresenter#HeaderContent">
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style Selector="DataGridCell.severity-cell">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!--  Combobox  -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ComboBox:pointerover /template/ Border#ToggleBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="ComboBox:focus /template/ Border#ToggleBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ Path#arrow:pointerover">
            <Setter Property="Fill" Value="{DynamicResource ForegroundBrush}" />
        </Style>

        <Style Selector="ComboBoxItem">
            <Setter Property="Width" Value="{Binding $parent[ComboBox].Bounds.Width}" />
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <!--  <Setter Property="Foreground"  -->
            <!--  Value="{DynamicResource SubtleForegroundBrush}" />  -->
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            >
                        <ContentPresenter Name="PART_ContentPresenter"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DarkAccentBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DarkAccentBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected:focus">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DarkAccentBrush}" />
        </Style>
        <Style Selector="ComboBoxItem TextBlock">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
        </Style>

        <Style Selector="ComboBoxItem:pointerover TextBlock">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="ComboBoxItem:selected TextBlock">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!--  ListBox  -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <!--  TabControl / TabItem  -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabControl /template/ ContentPresenter#PART_SelectedContentHost">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Width" Value="200" />
            <Setter Property="Height" Value="33" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource TabInactiveBackgroundBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="14,14,0,0"
                            >
                        <ContentPresenter Name="PART_HeaderPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}" />
            <Setter Property="Height" Value="40" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
        </Style>
        <Style Selector="TabItem:pointerover">
            <!--  <Setter Property="Background"  -->
            <!--  Value="{DynamicResource DarkAccentBrush}" />  -->
            <Setter Property="BorderBrush" Value="{DynamicResource DarkAccentBrush}" />
        </Style>


        <!--  Menu Separators  -->
        <Style Selector="Separator">
            <Setter Property="Background" Value="{DynamicResource SubtleForegroundBrush}" />
            <Setter Property="Height" Value="2" />
        </Style>

        <!--  ContextMenu (simple override)  -->
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            >
                        <ItemsPresenter Name="PART_ItemsPresenter" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>


        <!--  CheckBox ToggleSwitch  -->
        <Style Selector="CheckBox.toggle-switch">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Width="50"
                          Height="28"
                          Background="{DynamicResource TransparentBrush}"
                          >
                        <Border Name="Track"
                                Background="{DynamicResource BorderBrush}"
                                BorderBrush="{DynamicResource BorderMidBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                />
                        <Rectangle Name="Thumb"
                                   Width="24"
                                   Height="24"
                                   Margin="2"
                                   HorizontalAlignment="Left"
                                   Fill="{DynamicResource SubtleForegroundBrush}"
                                   RadiusX="12"
                                   RadiusY="12"
                                   Stroke="{DynamicResource BorderMidBrush}"
                                   StrokeThickness="1"
                                   />
                        <Border Name="Glow"
                                Width="50"
                                Height="28"
                                Background="{DynamicResource TransparentBrush}"
                                CornerRadius="14"
                                Opacity="0"
                                />
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:checked /template/ Rectangle#Thumb">
                <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="Margin" Value="2" />
            </Style>
            <Style Selector="^:not(:checked)">
                <Setter Property="Opacity" Value="0.4" />
            </Style>
            <Style Selector="^:pointerover /template/ Border#Glow">
                <Setter Property="Opacity" Value="0.2" />
                <Setter Property="Background" Value="{DynamicResource ForegroundBrush}" />
            </Style>
            <Style Selector="^:pointerover /template/ Border#Track">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="BorderThickness" Value="3" />
                <Setter Property="CornerRadius" Value="14" />
            </Style>
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip.Tip" Value="Apply this change to selected items" />
        </Style>


        <!--  Scrollbars  -->
        <Style Selector="RepeatButton#PART_LineUpButton.repeat">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="RepeatButton#PART_LineDownButton.repeat">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="RepeatButton#PART_PageUpButton.repeattrack">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="RepeatButton#PART_PageDownButton.repeattrack">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="ScrollBar Thumb">
            <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="14" />
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="14" />
        </Style>
        <Style Selector="ScrollBar:vertical Thumb">
            <Setter Property="Width" Value="5" />
        </Style>
        <Style Selector="ScrollBar:horizontal Thumb">
            <Setter Property="Height" Value="5" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb#thumb /template/ Border">
            <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ScrollBar /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

        <Style Selector="ScrollBar#PART_VerticalScrollbar:vertical /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ScrollBar#PART_HorizontalScrollbar:horizontal /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>


        <Style Selector="DataGrid /template/ Rectangle">
            <Setter Property="Fill" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="DataGrid /template/ Rectangle#PART_BottomRightCorner">
            <Setter Property="Fill" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>


        <Style Selector="ScrollViewer /template/ ScrollBar Thumb">
            <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar:vertical">
            <Setter Property="Width" Value="14" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar:horizontal">
            <Setter Property="Height" Value="14" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar:vertical Thumb">
            <Setter Property="Width" Value="5" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar:horizontal Thumb">
            <Setter Property="Height" Value="5" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar /template/ Thumb#thumb /template/ Border">
            <Setter Property="Background" Value="{DynamicResource DarkAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar#PART_VerticalScrollBar:vertical /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackground0Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar#PART_HorizontalScrollbar:horizontal /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar#PART_VerticalScrollBar:vertical /template/ RepeatButton#PART_PageDownButton.repeattrack">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar#PART_VerticalScrollBar:vertical /template/ RepeatButton#PART_PageUpButton.repeattrack">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar#PART_HorizontalScrollBar:horizontal /template/ RepeatButton#PART_PageDownButton.repeattrack">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar#PART_HorizontalScrollBar:horizontal /template/ RepeatButton#PART_PageUpButton.repeattrack">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBackgroundBrush}" />
        </Style>

    </Application.Styles>
</Application>