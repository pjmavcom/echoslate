<UserControl x:Class="Echoslate.Avalonia.Windows.TodoItemEditorWindow"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Echoslate.Avalonia.Behaviors"
             xmlns:converters="clr-namespace:Echoslate.Avalonia.Converters"
             xmlns:viewModels="clr-namespace:Echoslate.Core.ViewModels;assembly=Echoslate.Core"
             x:DataType="viewModels:TodoItemEditorViewModel"
             Background="{DynamicResource AppDarkBackgroundBrush}"
             >
    <UserControl.Resources>
        <converters:KanbanIndexToIDConverter x:Key="KanbanIndexToIdConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="486" />
            <ColumnDefinition Width="486" />
            <ColumnDefinition Width="486" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Margin="7"
              Column="0"
              >
            <Grid.RowDefinitions>
                <RowDefinition Height="180" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  TO DO Text  -->
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="7"
                    >
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Margin="1"
                            Padding="10,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Text="Title"
                                   />
                    </Border>
                    <TextBox Grid.Row="1"
                             Margin="1"
                             VerticalAlignment="Stretch"
                             AcceptsReturn="True"
                             FontSize="16"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Text="{Binding TodoText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             />
                </Grid>
            </Border>

            <!--  Notes  -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="7"
                    >
                <StackPanel>
                    <Border Margin="1"
                            Padding="10,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Text="Notes"
                                   />
                    </Border>

                    <TextBox Height="180"
                             Margin="1"
                             AcceptsReturn="True"
                             FontSize="16"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             />
                </StackPanel>
            </Border>

            <!--  Tags  -->
            <Border Grid.Row="2"
                    Grid.Column="0"
                    Margin="7"
                    >
                <StackPanel>
                    <Border Padding="10,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Text="Tags"
                                   />
                    </Border>
                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <Grid Margin="10,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Height="35"
                                    Margin="3"
                                    VerticalAlignment="Top"
                                    Command="{Binding AddTagCommand}"
                                    Content="Add Tag"
                                    FontSize="16"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    />
                            <ListBox Grid.Column="1"
                                     Height="150"
                                     Margin="0"
                                     Padding="7,0"
                                     ItemsSource="{Binding Tags}"
                                     SelectedItem="{Binding SelectedTag}"
                                     >
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Grid Height="35"
                                              Margin="7,0"
                                              >
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Height="24"
                                                    Padding="0"
                                                    Background="{DynamicResource DangerRedBrush}"
                                                    Command="{Binding $parent[UserControl].DataContext.DeleteTagCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="X"
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                    />
                                            <Label Grid.Column="1"
                                                   MinWidth="140"
                                                   Margin="8,0,0,0"
                                                   Padding="7,0"
                                                   VerticalContentAlignment="Center"
                                                   Background="{DynamicResource ButtonBackgroundBrush}"
                                                   BorderThickness="0,0,0,1"
                                                   Content="{Binding}"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!--  Properties  -->
        <Grid Margin="7"
              Column="1"
              >
            <Grid.RowDefinitions>
                <RowDefinition Height="180" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Margin="7"
                    >
                <Grid RowDefinitions="Auto,*">

                    <Border Padding="10,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Text="Properties"
                                   />
                    </Border>
                    <Border Grid.Row="1"
                            VerticalAlignment="Stretch"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <Grid Margin="10,15"
                              VerticalAlignment="Center"
                              >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Severity Button  -->
                                <Button Grid.Row="0"
                                        Grid.Column="0"
                                        Width="120"
                                        Height="40"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{Binding SeverityButtonBackground}"
                                        Classes="severity-button"
                                        Command="{Binding CycleSeverityCommand}"
                                        Content="Severity"
                                        FontSize="16"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        />

                                <!--  Rank  -->
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="0,0,10,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Text="Rank:"
                                           />
                                <Border Grid.Row="0"
                                        Grid.Column="2"
                                        Height="40"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1"
                                        >
                                    <NumericUpDown Width="80"
                                                   behaviors:MouseWheelNumericBehavior.Enabled="True"
                                                   behaviors:MouseWheelNumericBehavior.Minimum="0"
                                                   behaviors:MouseWheelNumericBehavior.TargetProperty="Rank"
                                                   Background="{DynamicResource TransparentBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FormatString="0"
                                                   IsEnabled="{Binding IsRankEnabled}"
                                                   Minimum="0"
                                                   TextAlignment="Center"
                                                   ToolTip.Tip="Mouse wheel: ±1 | Shift+wheel: ±5"
                                                   Value="{Binding Rank}"
                                                   />
                                </Border>
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Width="40"
                                        Height="30"
                                        Padding="0"
                                        Command="{Binding RankToTopCommand}"
                                        Content="▲▲"
                                        FontSize="16"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        IsEnabled="{Binding IsRankEnabled}"
                                        ToolTip.Tip="Move to top"
                                        />
                                <Button Grid.Row="0"
                                        Grid.Column="4"
                                        Width="40"
                                        Height="30"
                                        Padding="0"
                                        Command="{Binding RankToBottomCommand}"
                                        Content="▼▼"
                                        FontSize="16"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        IsEnabled="{Binding IsRankEnabled}"
                                        ToolTip.Tip="Move to bottom"
                                        />
                            </Grid>
                            <Grid Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                </Grid.ColumnDefinitions>

                                <!--  Severity Button  -->
                                <Button Grid.Row="0"
                                        Grid.Column="0"
                                        Width="120"
                                        Height="40"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{Binding PriorityButtonBackground}"
                                        Classes="severity-button"
                                        Command="{Binding CyclePriorityCommand}"
                                        Content="Priority"
                                        FontSize="16"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        />
                            </Grid>

                            <!--  Kanban  -->
                            <Grid Grid.Row="2"
                                  Grid.Column="0"
                                  >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Margin="3"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Text="Kanban:"
                                           />
                                <Button Grid.Column="1"
                                        Width="120"
                                        Margin="3"
                                        HorizontalAlignment="Left"
                                        Command="{Binding CycleKanbanCommand}"
                                        Content="{Binding KanbanId, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource KanbanIndexToIdConverter}}"
                                        FontSize="16"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        ToolTip.Tip="Kanban Status"
                                        />
                            </Grid>

                            <!--  Time  -->
                            <Grid Grid.Row="2"
                                  Grid.Column="1"
                                  Width="200"
                                  >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Margin="0,0,10,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Text="Time (min):"
                                           />
                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        Height="40"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1"
                                        >
                                    <NumericUpDown Width="80"
                                                   behaviors:MouseWheelNumericBehavior.Enabled="True"
                                                   behaviors:MouseWheelNumericBehavior.Minimum="0"
                                                   behaviors:MouseWheelNumericBehavior.TargetProperty="TimeInMinutes"
                                                   Background="{DynamicResource TransparentBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FormatString="0"
                                                   Minimum="0"
                                                   TextAlignment="Center"
                                                   ToolTip.Tip="Mouse wheel: ±1 | Shift+wheel: ±5"
                                                   Value="{Binding TimeInMinutes}"
                                                   />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!--  Problem  -->
            <Border Grid.Row="1"
                    Margin="7"
                    >
                <StackPanel>
                    <Border Margin="1"
                            Padding="10,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Text="Problem"
                                   />
                    </Border>
                    <TextBox Height="180"
                             Margin="1"
                             AcceptsReturn="True"
                             FontSize="16"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Text="{Binding Problem, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             />
                </StackPanel>
            </Border>

            <!--  Solution  -->
            <Border Grid.Row="2"
                    Margin="7"
                    >
                <StackPanel>
                    <Border Margin="1"
                            Padding="10,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSilverBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            >
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Text="Solution"
                                   />
                    </Border>
                    <TextBox Height="180"
                             Margin="1"
                             AcceptsReturn="True"
                             FontSize="16"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Text="{Binding Solution, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Reminders  -->
        <Grid Grid.Column="2">
            <DataGrid BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      DoubleTapped="DataGrid_DoubleTapped"
                      GridLinesVisibility="All"
                      IsReadOnly="True"
                      ItemsSource="{Binding Reminders}"
                      SelectedItem="{Binding SelectedReminder, Mode=TwoWay}"
                      >
                <DataGrid.Columns>
                    <!--  ~1~ Message  -->
                    <DataGridTemplateColumn MinWidth="300"
                                            Header="Message"
                                            >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Content="{Binding Message}"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       ToolTip.Tip="{Binding Message}"
                                       />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  ~2~ Due Date  -->
                    <DataGridTemplateColumn MinWidth="170"
                                            Header="Due Date"
                                            >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Content="{Binding DueDateString, StringFormat=yyyy-MM-dd}"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!--  Buttons  -->
        <StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,10,0,10"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    >
            <Button Classes="ok"
                    Click="Ok_OnClick"
                    Content="Save"
                    IsDefault="True"
                    />
            <Button Classes="cancel"
                    Click="Cancel_OnClick"
                    IsCancel="True"
                    />
            <Label Width="500"
                   Height="30"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   HorizontalContentAlignment="Right"
                   Content="{Binding Guid}"
                   FontSize="12"
                   Foreground="{DynamicResource SubtleForegroundBrush}"
                   />
        </StackPanel>
    </Grid>
</UserControl>