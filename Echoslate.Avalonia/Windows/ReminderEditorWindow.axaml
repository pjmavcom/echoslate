    <!--  <TextBlock VerticalAlignment="Center"  -->
    <!--  Text="Remind in advance:"  -->
    <!--  />  -->
    <!--  <ComboBox ItemsSource="{Binding AdvanceOptions}"  -->
    <!--  SelectedIndex="{Binding AdvanceMinutes}"  -->
    <!--  />  -->
    <!--         </StackPanel> -->
    <!--    -->
